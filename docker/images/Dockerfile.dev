# syntax=docker/dockerfile:1
FROM python:3.13

ENV DEBIAN_FRONTEND=noninteractive
ENV PIP_ROOT_USER_ACTION=ignore
ENV PYTHONPATH=/workspace

WORKDIR /workspace

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash openrc ca-certificates gnupg curl git \
        gcc libc-dev python3-dev libffi-dev build-essential \
        mariadb-client \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get update \
    && apt-get install -y --no-install-recommends nodejs \
    && node -v \
    && npm -v \
    && curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
        > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends docker-ce-cli \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN git config --global --add safe.directory /workspace

COPY package.json .
COPY pyproject.toml ./

# pip's wheel cache lives in a BuildKit cache mount so heavy sdist-only deps
# (python-sat, dd, gevent, *.dev pins) are compiled once and reused across builds.
RUN --mount=type=cache,target=/root/.cache/pip pip install --upgrade pip
RUN --mount=type=cache,target=/root/.cache/pip pip install --pre .
RUN --mount=type=cache,target=/root/.npm npm install

COPY app/ ./app
COPY rosemary/ ./rosemary
COPY migrations/ ./migrations
COPY docker/ ./docker
COPY --chmod=0755 scripts/ ./scripts/

# Install Rosemary (lives in ./rosemary with its own pyproject)
RUN --mount=type=cache,target=/root/.cache/pip pip install -e ./rosemary

RUN --mount=type=cache,target=/root/.cache/pip pip install -e ./app/features/generator/vendor

RUN find . -type d -name "__pycache__" -exec rm -r {} + \
 && find . -type f -name "*.pyc" -exec rm -f {} +

EXPOSE 5000
